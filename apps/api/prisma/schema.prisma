generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WordStatus {
  learning
  known
}

enum GrammarLevel {
  basic
  intermediate
  advanced
}

enum QuestionType {
  single_choice
  fill_blank
}

enum RootType {
  root
  prefix
  suffix
}

model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  passwordHash       String               @map("password_hash")
  createdAt          DateTime             @default(now()) @map("created_at")
  wordProgresses     UserWordProgress[]
  grammarAttempts    GrammarAttempt[]
  wordReviewEvents   UserWordReviewEvent[]
  dictationAttempts  DictationAttempt[]
  matchGameAttempts  MatchGameAttempt[]
  speakingAttempts   SpeakingAttempt[]
  clozeAttempts      ClozeAttempt[]
  focusSessions      FocusSession[]

  @@map("users")
}

model WordEntry {
  id              String             @id @default(uuid())
  word            String             @unique
  definition      String
  exampleSentence String             @map("example_sentence")
  phonetic        String             @default("")
  createdAt       DateTime           @default(now()) @map("created_at")
  progresses      UserWordProgress[]

  @@index([word])
  @@map("word_entries")
}

model UserWordProgress {
  id             String                @id @default(uuid())
  userId         String                @map("user_id")
  wordEntryId    String                @map("word_entry_id")
  status         WordStatus            @default(learning)
  easeFactor     Float                 @default(2.5) @map("ease_factor")
  intervalDays   Int                   @default(1) @map("interval_days")
  nextReviewAt   DateTime              @map("next_review_at")
  lastReviewedAt DateTime?             @map("last_reviewed_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordEntry      WordEntry             @relation(fields: [wordEntryId], references: [id], onDelete: Cascade)
  reviewEvents   UserWordReviewEvent[]

  @@unique([userId, wordEntryId])
  @@index([userId, nextReviewAt])
  @@map("user_word_progresses")
}

model UserWordReviewEvent {
  id                String           @id @default(uuid())
  userId            String           @map("user_id")
  progressId        String           @map("progress_id")
  clientEventId     String           @map("client_event_id")
  known             Boolean
  easeFactorAfter   Float            @map("ease_factor_after")
  intervalDaysAfter Int              @map("interval_days_after")
  reviewedAt        DateTime         @map("reviewed_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress          UserWordProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([userId, clientEventId])
  @@index([userId, reviewedAt])
  @@map("user_word_review_events")
}

model GrammarLesson {
  id          String           @id @default(uuid())
  title       String           @unique
  level       GrammarLevel
  content     String
  createdAt   DateTime         @default(now()) @map("created_at")
  questions   GrammarQuestion[]
  attempts    GrammarAttempt[]

  @@index([level])
  @@map("grammar_lessons")
}

model GrammarQuestion {
  id          String       @id @default(uuid())
  lessonId    String       @map("lesson_id")
  type        QuestionType
  prompt      String
  options     Json
  answer      String
  explanation String
  createdAt   DateTime     @default(now()) @map("created_at")

  lesson      GrammarLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("grammar_questions")
}

model GrammarAttempt {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  lessonId       String       @map("lesson_id")
  clientEventId  String       @map("client_event_id")
  score          Int
  totalQuestions Int          @map("total_questions")
  correctCount   Int          @map("correct_count")
  answers        Json
  createdAt      DateTime     @default(now()) @map("created_at")

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson         GrammarLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, clientEventId])
  @@index([userId, createdAt])
  @@map("grammar_attempts")
}

model DictationAttempt {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  clientEventId  String   @map("client_event_id")
  totalWords     Int      @map("total_words")
  correctCount   Int      @map("correct_count")
  accuracy       Float
  wordResults    Json     @map("word_results")
  createdAt      DateTime @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientEventId])
  @@index([userId, createdAt])
  @@map("dictation_attempts")
}

model MatchGameAttempt {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  clientEventId  String   @map("client_event_id")
  difficulty     String   @default("normal")
  wordCount      Int      @map("word_count")
  timeLimitSec   Int      @map("time_limit_sec")
  score          Int
  maxCombo       Int      @map("max_combo")
  matchedCount   Int      @map("matched_count")
  totalWords     Int      @map("total_words")
  timeUsedSec    Float    @map("time_used_sec")
  won           Boolean
  createdAt      DateTime @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientEventId])
  @@index([userId, createdAt])
  @@map("match_game_attempts")
}

model SpeakingAttempt {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  clientEventId   String   @map("client_event_id")
  wordEntryId     String?  @map("word_entry_id")
  targetText      String   @map("target_text")
  recognizedText  String   @map("recognized_text")
  similarityScore Float    @map("similarity_score")
  wordResults     Json     @map("word_results")
  totalWords      Int      @map("total_words")
  correctCount    Int      @map("correct_count")
  practiceMode    String   @map("practice_mode")
  createdAt       DateTime @default(now()) @map("created_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordEntry      WordEntry? @relation(fields: [wordEntryId], references: [id], onDelete: Cascade)

  @@unique([userId, clientEventId])
  @@index([userId, createdAt])
  @@map("speaking_attempts")
}

model ClozeAttempt {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  clientEventId  String   @map("client_event_id")
  wordEntryId    String   @map("word_entry_id")
  targetWord     String   @map("target_word")
  sentence       String   @map("sentence")
  userAnswer     String   @map("user_answer")
  correct        Boolean
  usedHint       Boolean  @map("used_hint")
  skipped        Boolean
  totalQuestions Int      @map("total_questions")
  correctCount   Int      @map("correct_count")
  accuracy       Float
  createdAt      DateTime @default(now()) @map("created_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordEntry      WordEntry @relation(fields: [wordEntryId], references: [id], onDelete: Cascade)

  @@unique([userId, clientEventId])
  @@index([userId, createdAt])
  @@map("cloze_attempts")
}

model WordRoot {
  id          String              @id @default(uuid())
  root        String
  type        RootType
  meaning     String
  origin      String              @default("")
  exampleWords String             @default("")
  createdAt   DateTime            @default(now()) @map("created_at")
  relations   WordRootRelation[]

  @@unique([root, type])
  @@index([type])
  @@map("word_roots")
}

model WordRootRelation {
  id          String     @id @default(uuid())
  rootId      String     @map("root_id")
  wordEntryId String     @map("word_entry_id")
  position    String     @default("")
  createdAt   DateTime   @default(now()) @map("created_at")

  root        WordRoot   @relation(fields: [rootId], references: [id], onDelete: Cascade)
  wordEntry   WordEntry  @relation(fields: [wordEntryId], references: [id], onDelete: Cascade)

  @@unique([rootId, wordEntryId])
  @@index([rootId])
  @@index([wordEntryId])
  @@map("word_root_relations")
}

enum FocusPhase {
  focus
  short_break
  long_break
}

model FocusSession {
  id             String     @id @default(uuid())
  userId         String     @map("user_id")
  clientEventId  String     @map("client_event_id")
  phase          FocusPhase
  durationSec    Int        @map("duration_sec")
  startedAt      DateTime   @map("started_at")
  endedAt        DateTime   @map("ended_at")
  completed      Boolean    @default(false)
  interrupted    Boolean    @default(false)
  actualDurationSec Int     @map("actual_duration_sec")
  createdAt      DateTime   @default(now()) @map("created_at")

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientEventId])
  @@index([userId, startedAt])
  @@map("focus_sessions")
}
